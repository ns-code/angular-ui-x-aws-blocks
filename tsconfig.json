{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "lib": [
      "ESNext",
      "DOM"
    ],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "build-temp",
          "types": ["node", "vitest"]
  },
  "include": [
    "src/**/*",
    "aws-blocks/**/*",
    "test/**/*",
    "src/**/*.d.ts"
  ]
}
